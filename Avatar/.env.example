# Copy to .env and fill in. NEVER commit .env.
# All keys live only on the server; the browser only ever gets a short-lived
# ephemeral Realtime token.

OPENAI_API_KEY=sk-...

# The "talking model" (voice frontend). OpenAI's example uses gpt-realtime-2;
# gpt-realtime is the GA alias. Change here if your account exposes another id.
REALTIME_MODEL=gpt-realtime-2
REALTIME_VOICE=marin

# The "avatar manager" — decides mood/gesture from the conversation.
# Small + cheap. This is the piece you'll later move to AWS Bedrock.
AVATAR_MANAGER_MODEL=gpt-4o-mini

PORT=3000

# ---- LATER: Bedrock-hosted avatar manager (no AWS key yet) ----------------
# When you have AWS creds, set AVATAR_MANAGER_BACKEND=bedrock, fill these in,
# run `npm i @aws-sdk/client-bedrock-runtime`, and uncomment the Bedrock branch
# in avatarManager.js. The rest of the app is unchanged.
# AVATAR_MANAGER_BACKEND=openai
# AWS_REGION=us-west-2
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# BEDROCK_MODEL_ID=openai.gpt-oss-20b-1:0
